# ============================================
# Credit Card Data Extractor — Production Config
# ============================================
# Copy to .env and edit as needed

# Port to expose the app (default 80)
APP_PORT=80

# Domain name (used by SSL setup script)
DOMAIN=example.com

# MongoDB (uses internal Docker network by default)
# MONGODB_URL=mongodb://mongo:27017

# Ollama models to auto-pull on first boot
OLLAMA_MODELS=nomic-embed-text,llama3.2
